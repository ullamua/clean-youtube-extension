{
  "manifest_version": 3,
  "name": "YT Clean Link",
  "version": "1.1.0",
  "description": "Generate clean, shareable MP4 links for YouTube videos with quality control.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": ["*://www.youtube.com/*", "*://youtube.com/*"]
}
